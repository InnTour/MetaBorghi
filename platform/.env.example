# ============================================================
# MetaBorghi Platform — Environment Variables
# Copia in .env.local e compila con i valori reali
# ============================================================

# --- Database (MySQL esistente su Hostinger) ---
DATABASE_URL="mysql://user:password@localhost:3306/metaborghi"

# --- NextAuth v5 ---
AUTH_SECRET="genera-con-openssl-rand-base64-32"
AUTH_URL="https://metaborghi.org"

# --- Legacy PHP API (proxy durante migrazione) ---
PHP_API_BASE="https://metaborghi.org"
PHP_API_TOKEN="token-api-legacy"

# --- Stripe (Fase 2+) ---
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# --- AI / Cicerone (Fase V2) ---
# OPENAI_API_KEY=""
# ELEVENLABS_API_KEY=""

# --- Node.js ---
NODE_ENV="production"
